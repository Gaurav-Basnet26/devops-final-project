pipeline {

    agent any

    environment {
        PATH = "/usr/local/bin:/opt/homebrew/bin:/usr/bin:/bin:/usr/sbin:/sbin"
    }

    stages {

        stage('Checkout') {
            steps {
                checkout scm
            }
        }

        stage('OpenTofu Init') {
            steps {
                dir('terraform') {
                    sh 'tofu init'
                }
            }
        }

        stage('OpenTofu Validate') {
            steps {
                dir('terraform') {
                    sh 'tofu validate'
                }
            }
        }

        stage('OpenTofu Plan') {
            steps {
                dir('terraform') {
                    sh 'tofu plan'
                }
            }
        }

        stage('OpenTofu Apply') {
            steps {
                dir('terraform') {
                    sh 'tofu apply -auto-approve'
                }
            }
        }

    }

    post {
        success {
            echo 'Infrastructure created successfully!'
        }

        failure {
            echo 'Infrastructure deployment failed!'
        }
    }
}
